{  "name": "serralheria-erp-localfirst",  "private": true,  "scripts": {    "docker:up": "docker-compose up -d",    "docker:down": "docker-compose down",    "dev:web": "pnpm --filter web dev",    "dev:api": "pnpm --filter api dev",    "build:web": "pnpm --filter web build",    "build:api": "pnpm --filter api build",    "build": "pnpm -r run build",    "prisma:generate": "pnpm --filter api exec prisma generate",    "prisma:migrate": "pnpm --filter api exec prisma migrate dev",    "prisma:seed": "pnpm --filter api exec prisma db seed",    "lint": "pnpm -r run lint",    "format": "prettier --write \"**/*.{ts,tsx,js,json}\""  },  "devDependencies": {    "prettier": "^3.2.5"  },  "packageManager": "pnpm@9.0.0",  "engines": {    "node": ">=20"  }}